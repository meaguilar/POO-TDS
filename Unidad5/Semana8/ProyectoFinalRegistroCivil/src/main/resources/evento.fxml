<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.proyecto.controlador.EventoControlador"
           prefWidth="550" prefHeight="500">

    <!-- Todo tu formulario dentro de un VBox -->
    <VBox spacing="25" alignment="CENTER">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <Label text="REGISTRO DE NACIMIENTO"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <GridPane hgap="20" vgap="20" alignment="CENTER">

            <!-- Folio -->
            <Label text="Folio:" style="-fx-font-size: 16px;"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtFolio" prefWidth="260"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <!-- Número Acta -->
            <Label text="Número de Acta:" style="-fx-font-size: 16px;"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtNumActa" prefWidth="260"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- Hora -->
            <Label text="Hora:" style="-fx-font-size: 16px;"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>

            <HBox spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="1">
                <Spinner fx:id="spHora" prefWidth="80"/>
                <Label text=":"/>
                <Spinner fx:id="spMinuto" prefWidth="80"/>
            </HBox>

            <!-- Fecha -->
            <Label text="Fecha Nacimiento:" style="-fx-font-size: 16px;"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpFechaNacimiento" prefWidth="260"
                        GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- Lugar -->
            <Label text="Lugar de nacimiento:" style="-fx-font-size: 16px;"
                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbDepartamento" prefWidth="260"
                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        </GridPane>

        <HBox spacing="20" alignment="CENTER">
            <Button text="Guardar Evento"
                    fx:id="btnGuardarEvento"
                    onAction="#guardarEvento"
                    prefWidth="160" prefHeight="45"/>
        </HBox>

        <!-- RESULTADO -->
        <VBox spacing="10" alignment="CENTER">
            <Label text="Eventos Registrados"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <TextArea fx:id="txtResultado"
                      prefWidth="450"
                      prefHeight="150"
                      editable="false"
                      wrapText="true"/>
        </VBox>
    </VBox>

    <!-- ProgressIndicator superpuesto y centrado -->
    <ProgressIndicator fx:id="progressIndicator"
                       visible="false"
                       prefWidth="80"
                       prefHeight="80"/>
</StackPane>